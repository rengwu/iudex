{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "iudex",
  "version": "0.2.0",
  "identifier": "com.rengwu.iudex",
  "build": {
    "beforeDevCommand": "pnpm build:cli && pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build:cli && pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "iudex",
        "width": 1189,
        "height": 722,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/iudex-cli"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
